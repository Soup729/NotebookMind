# Database
POSTGRES_DSN=host=localhost user=postgres password=postgres dbname=pdf_ai port=5432 sslmode=disable TimeZone=Asia/Shanghai
REDIS_ADDR=localhost:6380
REDIS_PASSWORD=

# Milvus / Zilliz Cloud (可选，本地开发可留空)
MILVUS_ADDRESS=
MILVUS_USERNAME=
MILVUS_PASSWORD=
MILVUS_COLLECTION_NAME=pdf_chunks

# OpenAI (必须)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Anthropic Claude (可选 - 启用后可切换到 Claude 模型)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-20250514

# Google Gemini (可选 - 启用后可切换到 Gemini 模型)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_CHAT_MODEL=gemini-2.0-flash

# 默认 LLM 提供商: openai | anthropic | gemini | custom
LLM_DEFAULT_PROVIDER=openai

# JWT (必须)
JWT_SECRET=generate-a-secure-random-string-here

# Upload
UPLOAD_LOCAL_DIR=tmp/uploads
UPLOAD_MAX_FILE_SIZE_MB=20
UPLOAD_ALLOWED_EXT=.pdf

# Worker
ASYNQ_CONCURRENCY=10

# Chat
CHAT_HISTORY_LIMIT=20
CHAT_RETRIEVAL_TOP_K=5

# ========== Phase 1: 结构化文档解析 ==========
# Parser (文档解析)
PARSER_CHUNK_SIZE=1000           # 父块最大字符数
PARSER_CHUNK_OVERLAP=200          # 父块重叠字符数
PARSER_CHILD_CHUNK_SIZE=300       # 子块（用于召回）最大字符数

# OCR 服务（扫描件识别）
OCR_PROVIDER=fallback             # "rapidocr" | "fallback"
OCR_BASE_URL=                     # RapidOCR 地址，如 http://localhost:8868

# VLM 视觉语言模型（图片描述生成，可选）
VLM_ENABLED=false                 # 启用 VLM 图片描述
VLM_API_KEY=                      # API Key（默认复用 OPENAI_API_KEY）
VLM_BASE_URL=                     # Base URL（默认复用 OPENAI_BASE_URL）
VLM_MODEL=gpt-4o-mini             # 模型名称
